<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/editRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/page_padding"
        android:paddingEnd="@dimen/page_padding">

        <TextView
            android:id="@+id/btnEditBack"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_secondary_cta"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="返回"
            android:textColor="@color/primary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="新增潜水记录"
            android:textColor="@color/ink"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/page_padding">

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_field"
                android:hint="标题，例如：三亚珊瑚礁观察"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:hint="地点"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:hint="日期，例如：2026-06-12"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etQuota"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:hint="最大深度（米）"
                android:inputType="numberDecimal"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etOrganizer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:hint="潜水时长（分钟）"
                android:inputType="number"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etVisibility"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:hint="能见度，例如：清晰 / 偏低"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etWaterTemp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:hint="水温感受，例如：温暖 / 偏冷"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etBuddy"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:hint="潜伴 / 教练"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etFish"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:hint="观察鱼类，例如：小丑鱼、蝶鱼"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="132dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:gravity="top"
                android:hint="潜水笔记：路线、感受、装备、注意事项"
                android:inputType="textMultiLine"
                android:paddingTop="12dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="@dimen/page_padding"
        android:layout_marginEnd="@dimen/page_padding"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_cta"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="保存记录"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
