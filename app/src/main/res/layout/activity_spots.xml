<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/spotsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="178dp"
        android:background="@drawable/bg_dashboard_header"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_padding"
        android:paddingEnd="@dimen/page_padding"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/btnSpotBack"
            android:layout_width="72dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_secondary_cta"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="返回"
            android:textColor="@color/primary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="潜点发现"
            android:textColor="@color/white"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="根据你的记录，整理相似潜水员常去的潜点"
            android:textColor="#D8ECFF"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/page_padding"
        android:paddingTop="14dp"
        android:paddingEnd="@dimen/page_padding">

        <EditText
            android:id="@+id/etSpotSearch"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_field"
            android:hint="搜索地点、类型、鱼类"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnSpotSearch"
            android:layout_width="78dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_cta"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="搜索"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/page_padding"
        android:paddingTop="14dp"
        android:paddingEnd="@dimen/page_padding"
        android:text="相似潜水员也常去"
        android:textColor="@color/ink"
        android:textSize="17sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSpots"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/page_padding" />
</LinearLayout>
